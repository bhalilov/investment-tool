{
  "version": 1,
  "modules": [
    {
      "module_id": "x-capture",
      "platform": "x",
      "kind": "social_capture",
      "entrypoint": "investment_tool.feeds.x.capture",
      "feed_config": "config/feeds/x_accounts.json",
      "supports": [
        "live_capture",
        "raw_api_rebuild",
        "missing_media_recovery",
        "photo_media_download",
        "non_photo_placeholders"
      ],
      "workflow_stages": [
        {"stage": "x-capture", "runner": "x_action", "action": "x-capture"},
        {"stage": "x-raw", "runner": "x_action", "action": "x-raw-rebuild"},
        {"stage": "x-reindex", "runner": "x_action", "action": "x-reindex"},
        {"stage": "x-repair-media-paths", "runner": "x_action", "action": "x-repair-media-paths"},
        {"stage": "x-recover-media", "runner": "x_action", "action": "x-recover-media"},
        {"stage": "render", "runner": "x_action", "action": "x-rerender"}
      ]
    },
    {
      "module_id": "articles",
      "platform": "web_archive",
      "kind": "article_archive",
      "entrypoint": "investment_tool.feeds.articles.ingest",
      "feed_config": "config/feeds/web_archives.json",
      "supports": [
        "manual_archive_ingest",
        "text_only_ai_analysis"
      ],
      "workflow_stages": [
        {"stage": "articles", "runner": "module_main", "argv": ["--feed-config", "{feed_config}"]}
      ]
    },
    {
      "module_id": "screenshots",
      "platform": "manual_screenshots",
      "kind": "manual_capture",
      "entrypoint": "investment_tool.feeds.screenshots.bundles",
      "feed_config": "config/feeds/x_accounts.json",
      "supports": [
        "screenshot_bundle_import",
        "overlap_stitching_ai_reconstruction"
      ],
      "workflow_stages": [
        {"stage": "screenshots", "runner": "screenshots_inbox"}
      ]
    },
    {
      "module_id": "prices",
      "platform": "market_data",
      "kind": "context_data",
      "entrypoint": "investment_tool.context.prices",
      "supports": [
        "daily_ohlcv",
        "usd_conversion"
      ],
      "workflow_stages": [
        {"stage": "prices", "runner": "module_main"}
      ]
    },
    {
      "module_id": "descriptions",
      "platform": "media_context",
      "kind": "context_data",
      "entrypoint": "investment_tool.context.descriptions",
      "feed_config": "config/feeds/x_accounts.json",
      "supports": [
        "neutral_image_description",
        "ocr_visible_text"
      ],
      "workflow_stages": [
        {"stage": "descriptions", "runner": "descriptions"}
      ]
    }
  ]
}
